# ============================================
# Keepomat — Umgebungsvariablen
# ============================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Auth (Pflicht!) ---
BETTER_AUTH_SECRET=CHANGE_ME_USE_openssl_rand_base64_48
BETTER_AUTH_URL=http://localhost:3000

# --- Datenbank ---
DATABASE_URL=./data/keepomat.db

# --- AI / Moonshot (Kimi) ---
# Kann auch im Admin-Panel konfiguriert werden
MOONSHOT_API_KEY=
AI_MODEL=kimi-k2-turbo-preview

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=

# --- Docker / NAS ---
PUID=1000
PGID=1000
