# Keepomat – HTTPS Reverse Proxy
#
# Caddy generiert automatisch ein selbstsigniertes Zertifikat (tls internal).
# Beim ersten Zugriff im Browser einmalig akzeptieren,
# oder Caddy Root-CA auf den Geräten installieren (siehe README).
#
# Der Hostname wird über die Env-Variable CADDY_HOST gesteuert (Standard: localhost).
# Für LAN-Zugriff in docker-compose.yml setzen:
#   environment:
#     - CADDY_HOST=192.168.1.100

{$CADDY_HOST:localhost} {
	tls internal
	reverse_proxy keepomat:3000
}
